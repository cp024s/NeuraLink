# Switch this file manually before running FPGA/PD commands.

# FPGA Vivado invocation mode:
#   wsl -> run Windows Vivado from WSL using cmd.exe
#   win -> run from native Windows shell
export VIVADO_MODE=wsl

# Vivado executable on Windows host
export VIVADO_BAT='C:\Xilinx\2025.1\Vivado\bin\vivado.bat'

# FPGA defaults
export TOP_MODULE=edge_tpu_top
export FPGA_PART=xc7a200tfbg484-1

# PD defaults
export PDK_NAME=openrpd28
